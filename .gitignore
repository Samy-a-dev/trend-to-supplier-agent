.env
.env.*
!.env.example
!.env.local.example

# python sidecar
/.venv
venv/
__pycache__/
*.pyc

# generated assets
/data/images/*
!/data/images/.gitkeep

# typescript
*.tsbuildinfo

# generated concept images
/public/generated/*
!/public/generated/.gitkeep
