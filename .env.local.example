# ─── Apify ───────────────────────────────────────────────
APIFY_TOKEN=
# Optional: auto-used in order when APIFY_TOKEN runs out of credits / hits its usage limit
APIFY_TOKEN_BACKUP=
APIFY_TOKEN_BACKUP2=
# Optional scrape cache controls. TTL defaults to 24h; same-vertical fallback defaults on.
SCRAPE_CACHE_TTL_MS=
SCRAPE_CACHE_VERTICAL_FALLBACK=

# ─── Tavily ──────────────────────────────────────────────
TAVILY_API_KEY=
# Optional; defaults to 20000
TAVILY_SEARCH_TIMEOUT_MS=

# ─── ClickHouse Cloud ────────────────────────────────────
# url like https://<host>.clickhouse.cloud:8443
CLICKHOUSE_URL=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ─── Gemini (Google AI) — text + Nano Banana images ──────
GEMINI_API_KEY=

# ─── Prometheux (Vadalog reasoning, via Python sidecar) ──
PMTX_TOKEN=
PMTX_ORG=
PMTX_USER=
SIDECAR_URL=http://localhost:8000

# ─── Gmail draft creation (OAuth desktop app) ────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
